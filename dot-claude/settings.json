{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_SHELL": "bash",
    "CLAUDE_ENV_FILE": "/home/janozeli/.claude/env.sh",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/gh-auth-guard"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/hooks/statusline --debug"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "brave-search-skills@brave-search": true,
    "claude-md-management@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "brave-search": {
      "source": {
        "source": "github",
        "repo": "brave/brave-search-skills"
      }
    }
  },
  "advisorModel": "opus",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "language": "Português Brasileiro"
}
