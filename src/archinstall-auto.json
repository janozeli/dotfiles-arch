{
  "archinstall-language": "English",
  "audio_config": {
    "audio": "pipewire"
  },
  "bootloader_config": {
    "bootloader": "Systemd-boot",
    "uki": false,
    "removable": false
  },
  "debug": false,
  "hostname": "arch",
  "kernels": [
    "linux",
    "linux-lts"
  ],
  "locale_config": {
    "kb_layout": "us,br",
    "sys_lang": "pt_BR.UTF-8",
    "sys_enc": "UTF-8"
  },
  "network_config": {
    "type": "nm"
  },
  "ntp": true,
  "timezone": "America/Sao_Paulo",
  "disk_config": {
    "config_type": "default_layout",
    "device_modifications": []
  },
  "profile_config": {
    "profile": {
      "name": "cosmic",
      "type": "desktop"
    }
  },
  "swap": true,
  "custom_commands": [
    "echo 'lucas-janozeli ALL=(ALL) NOPASSWD: ALL' > /mnt/archinstall/etc/sudoers.d/lucas-janozeli",
    "chmod 440 /mnt/archinstall/etc/sudoers.d/lucas-janozeli"
  ]
}
