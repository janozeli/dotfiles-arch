#!/usr/bin/env bash
set -euo pipefail

if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
	video=$(wl-paste)
elif [ "$XDG_SESSION_TYPE" = "x11" ]; then
	video=$(xclip -selection clipboard -o)
else
	echo "vd: unsupported session type: $XDG_SESSION_TYPE" >&2
	exit 1
fi

if [ -z "$video" ]; then
	echo "vd: clipboard is empty" >&2
	exit 1
fi

nohup mpv "$video" &
