#!/usr/bin/env bash
set -euo pipefail

if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
	video=$(wl-paste)
elif [ "$XDG_SESSION_TYPE" = "x11" ]; then
	video=$(xclip -selection clipboard -o)
else
	notify-send "vd" "Unsupported session type: $XDG_SESSION_TYPE"
	exit 1
fi

if [ -z "$video" ]; then
	notify-send "vd" "Clipboard is empty"
	exit 1
fi

mpv "$video" || notify-send "vd" "Failed to play: $video"
